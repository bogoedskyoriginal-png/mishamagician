RewriteEngine On

# API stays as-is
RewriteRule ^api\.php$ - [L]

# Admin panel
RewriteRule ^a/([A-Za-z0-9_-]{1,32})$ admin.html [L,QSA]

# Master admin
RewriteRule ^crp$ crp.html [L,QSA]
RewriteRule ^master$ crp.html [L,QSA]

# Viewer root
RewriteRule ^$ index.html [L,QSA]

# Viewer slug
RewriteRule ^([A-Za-z0-9_-]{1,32})$ index.html [L,QSA]
